{
  "name": "promptly",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "bin": {
    "promptly": "bin/promptly.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:e2e": "vite build --mode e2e --outDir dist-e2e",
    "build:cli": "vite build --config vite.cli.config.ts && node scripts/copy-engine.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:e2e && playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.110.1",
    "compromise": "^14.15.1",
    "diff-match-patch": "^1.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
